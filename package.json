{
  "name": "sincrack-rdm",
  "version": "1.0.0",
  "description": "SinCracK Remote Desktop & Connection Manager",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.sincrack.rdm",
    "productName": "SinCracK RDM",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/icon.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "lucide-react": "^0.378.0",
    "mysql2": "^3.22.3",
    "node-forge": "^1.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/ssh2": "^1.11.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
